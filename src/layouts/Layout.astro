---
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Default site description" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />

		<slot name="head" />
	</head>

	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		flex-direction: column;
		display: flex;
	}

	:global(body) {
		margin: 0;
		font-family:
			"Open Sans",
			ui-sans-serif,
			system-ui,
			-apple-system,
			Segoe UI,
			Roboto,
			Helvetica,
			Arial,
			sans-serif;
		color: var(--color-text-primary);
		background: var(--color-surface-background);
	}

	:root {
		/* Colors */
		--color-text-primary: rgb(46, 46, 47);
		--color-text-secondary: #374151;
		--color-text-dark: #111827;
		--color-surface-background: rgb(245, 245, 247);
		--color-surface-muted: rgb(213, 227, 235);
		--color-brand-quaternary: #95cbd2;
		--color-brand-tertiary: #97b9cd;
		--color-brand-secondary: rgb(72, 146, 190);
		--color-brand-secondary-hover: #3a7aa8;
		--color-brand-primary: rgb(43, 94, 186);

		/* Drop Shadow */
		--shadow-image: 0px 8px 17px -11px #2e2e2f80;

		/* Transitions */
		--transition-fast: 140ms ease;

		/* Font Families */
		--font-inter: "Inter", sans-serif;
		--font-open-sans: "Open Sans", sans-serif;
		--font-source-sans: "Source Sans 3", sans-serif;
		--font-manrope: "Manrope", sans-serif;

		/* Font Sizes */
		--text-sm: 16px;
		--text-md: 24px;
		--text-lg: 32px;
		--text-xl: 40px;

		/* Letter Spacing */
		--tracking-0: 0em;
		--tracking-1: 0.03em;
		--tracking-2: 0.05em;
		--tracking-3: 0.07em;
	}
</style>

<style is:global>
	/* Page heading: old slides up and fades, new slides up from below */
	::view-transition-old(page-heading) {
		animation: 180ms ease-in both vt-heading-out;
	}

	::view-transition-new(page-heading) {
		animation: 240ms ease-out 120ms both vt-heading-in;
	}

	@keyframes vt-heading-out {
		to {
			opacity: 0;
			transform: translateY(-10px);
		}
	}

	@keyframes vt-heading-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
	}

	/* Images start hidden; JS adds .img-animate to trigger the entrance */
	@media (prefers-reduced-motion: no-preference) {
		img:not(.nav-logo):not(.content__arrow):not(.hero__img) {
			opacity: 0;
			transform: translateY(18px);
		}

		img:not(.nav-logo):not(.content__arrow).img-animate {
			animation: img-fade-up 350ms ease-out both;
			animation-delay: var(--img-delay, 0ms);
		}

		@keyframes img-fade-up {
			from {
				opacity: 0;
				transform: translateY(18px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	}

	@font-face {
		font-family: "Manrope";
		src: url("/fonts/Manrope-Regular.ttf") format("truetype");
		font-weight: 400;
		font-style: normal;
	}

	@font-face {
		font-family: "Manrope";
		src: url("/fonts/Manrope-Light.ttf") format("truetype");
		font-weight: 300;
		font-style: normal;
	}

	@font-face {
		font-family: "Manrope";
		src: url("/fonts/Manrope-ExtraLight.ttf") format("truetype");
		font-weight: 200;
		font-style: normal;
	}
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.btn-pill {
		display: inline-block;
		background: var(--color-brand-secondary);
		color: var(--color-surface-background);
		text-decoration: none;
		font-size: 24px;
		font-weight: 300;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 21px 81px 22px;
		border-radius: 50px;
		transition:
			background 140ms ease,
			transform 140ms ease;
		box-shadow: var(--shadow-image);
	}

	.btn-pill:hover {
		background: var(--color-brand-secondary-hover);
		transform: translateY(-1px);
	}
</style>

<!-- Reveal images if JS is disabled -->
<noscript>
	<style>
		img {
			opacity: 1 !important;
			transform: none !important;
		}
	</style></noscript
>

<script>
	const IMG_SELECTOR = "img:not(.nav-logo):not(.content__arrow)";
	const STAGGER_MS = 60;
	const THRESHOLD = 0.4;

	function setupImageAnimations() {
		const reducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		const images = Array.from(
			document.querySelectorAll<HTMLElement>(IMG_SELECTOR),
		);

		// Reset any previous run
		images.forEach((img) => {
			img.classList.remove("img-animate");
			img.style.removeProperty("--img-delay");
		});

		if (reducedMotion || window.location.pathname === "/") {
			// Skip animation; make sure images are visible
			images.forEach((img) => {
				img.style.opacity = "1";
				img.style.transform = "none";
			});
			return;
		}

		const vh = window.innerHeight;
		const inView: HTMLElement[] = [];
		const outOfView: HTMLElement[] = [];

		images.forEach((img) => {
			const rect = img.getBoundingClientRect();
			const visible = Math.min(rect.bottom, vh) - Math.max(rect.top, 0);
			const pct = rect.height > 0 ? visible / rect.height : 0;
			(pct >= THRESHOLD ? inView : outOfView).push(img);
		});

		// Stagger in-viewport images immediately
		inView.forEach((img, i) => {
			img.style.setProperty("--img-delay", `${i * STAGGER_MS}ms`);
			img.classList.add("img-animate");
		});

		// Scroll-trigger out-of-viewport images at 40% visibility
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						(entry.target as HTMLElement).classList.add(
							"img-animate",
						);
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: THRESHOLD },
		);

		outOfView.forEach((img) => observer.observe(img));
	}

	// Initial page load + every view-transition navigation
	document.addEventListener("astro:page-load", setupImageAnimations);
</script>
