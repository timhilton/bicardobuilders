---
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Default site description" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />

		<slot name="head" />
	</head>

	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		flex-direction: column;
		display: flex;
	}

	:global(body) {
		margin: 0;
		font-family:
			"Open Sans",
			ui-sans-serif,
			system-ui,
			-apple-system,
			Segoe UI,
			Roboto,
			Helvetica,
			Arial,
			sans-serif;
		color: var(--color-text-primary);
		background: var(--color-surface-background);
	}

	:root {
		/* Colors */
		--color-text-primary: rgb(46, 46, 47);
		--color-text-secondary: #374151;
		--color-text-dark: #111827;
		--color-surface-background: rgb(245, 245, 247);
		--color-surface-muted: rgb(213, 227, 235);
		--color-brand-quaternary: #95cbd2;
		--color-brand-tertiary: #97b9cd;
		--color-brand-secondary: rgb(72, 146, 190);
		--color-brand-secondary-hover: #3a7aa8;
		--color-brand-primary: rgb(43, 94, 186);

		/* Drop Shadow */
		--shadow-image: 0px 8px 17px -11px #2e2e2f80;

		/* Transitions */
		--transition-fast: 140ms ease;

		/* Font Families */
		--font-inter: "Inter", sans-serif;
		--font-open-sans: "Open Sans", sans-serif;
		--font-source-sans: "Source Sans 3", sans-serif;
		--font-manrope: "Manrope", sans-serif;

		/* Font Sizes */
		--text-sm: 16px;
		--text-md: 24px;
		--text-lg: 32px;
		--text-xl: 40px;

		/* Letter Spacing */
		--tracking-0: 0em;
		--tracking-1: 0.03em;
		--tracking-2: 0.05em;
		--tracking-3: 0.07em;
	}
</style>

<style is:global>
	@keyframes heading-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}


/* Images start hidden; JS adds .img-animate to trigger the entrance */
	@media (prefers-reduced-motion: no-preference) {
		img:not(.nav-logo):not(.content__arrow):not(.hero__img):not(.img-done) {
			opacity: 0;
			transform: translateY(18px);
		}

		img:not(.nav-logo):not(.content__arrow):not(.hero__img).img-animate {
			animation: img-fade-up 350ms ease-out both;
			animation-delay: var(--img-delay, 0ms);
		}

		@keyframes img-fade-up {
			from {
				opacity: 0;
				transform: translateY(18px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	}

	@font-face {
		font-family: "Manrope";
		src: url("/fonts/Manrope-Regular.ttf") format("truetype");
		font-weight: 400;
		font-style: normal;
	}

	@font-face {
		font-family: "Manrope";
		src: url("/fonts/Manrope-Light.ttf") format("truetype");
		font-weight: 300;
		font-style: normal;
	}

	@font-face {
		font-family: "Manrope";
		src: url("/fonts/Manrope-ExtraLight.ttf") format("truetype");
		font-weight: 200;
		font-style: normal;
	}
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.btn-pill {
		display: inline-block;
		background: var(--color-brand-secondary);
		color: var(--color-surface-background);
		text-decoration: none;
		font-size: 24px;
		font-weight: 300;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 21px 81px 22px;
		border-radius: 50px;
		transition:
			background 140ms ease,
			transform 140ms ease;
		box-shadow: var(--shadow-image);
		position: relative;
		overflow: hidden;
	}

	.btn-pill::after {
		content: '';
		position: absolute;
		top: 0;
		left: -75%;
		width: 50%;
		height: 100%;
		background: linear-gradient(
			120deg,
			transparent 0%,
			rgba(255, 255, 255, 0.25) 50%,
			transparent 100%
		);
		transition: none;
	}

	.btn-pill:hover::after {
		animation: btn-shimmer 600ms ease forwards;
	}

	@keyframes btn-shimmer {
		0%   { left: -75%; }
		100% { left: 150%; }
	}

	.btn-pill:hover {
		background: var(--color-brand-secondary-hover);
		transform: translateY(-1px);
	}

	.hero__gallery {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.hero__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0;
		transition: opacity 1.5s ease;
	}
</style>

<!-- Reveal images if JS is disabled -->
<noscript>
	<style>
		img {
			opacity: 1 !important;
			transform: none !important;
		}
	</style></noscript
>

<script>
	const IMG_SELECTOR = "img:not(.nav-logo):not(.content__arrow):not(.hero__img)";
	const STAGGER_MS = 60;
	const THRESHOLD = 0.4;

	function setupImageAnimations() {
		const reducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		const images = Array.from(
			document.querySelectorAll<HTMLElement>(IMG_SELECTOR),
		);

		// Reset any previous run
		images.forEach((img) => {
			img.classList.remove("img-animate", "img-done");
			img.style.removeProperty("--img-delay");
		});

		if (reducedMotion || window.location.pathname === "/") {
			// Skip animation; make sure images are visible
			images.forEach((img) => {
				img.style.opacity = "1";
				img.style.transform = "none";
			});
			return;
		}

		const vh = window.innerHeight;
		const inView: HTMLElement[] = [];
		const outOfView: HTMLElement[] = [];

		images.forEach((img) => {
			const rect = img.getBoundingClientRect();
			const visible = Math.min(rect.bottom, vh) - Math.max(rect.top, 0);
			const pct = rect.height > 0 ? visible / rect.height : 0;
			(pct >= THRESHOLD ? inView : outOfView).push(img);
		});

		const clearAnim = (img: HTMLElement) => {
			img.addEventListener("animationend", () => {
				img.classList.add("img-done");
				img.classList.remove("img-animate");
			}, { once: true });
		};

		// Stagger in-viewport images immediately
		inView.forEach((img, i) => {
			img.style.setProperty("--img-delay", `${i * STAGGER_MS}ms`);
			img.classList.add("img-animate");
			clearAnim(img);
		});

		// Scroll-trigger out-of-viewport images at 40% visibility
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					const img = entry.target as HTMLElement;
					if (entry.isIntersecting) {
						img.classList.add("img-animate");
						clearAnim(img);
						observer.unobserve(img);
					}
				});
			},
			{ threshold: THRESHOLD },
		);

		outOfView.forEach((img) => observer.observe(img));
	}

	const HEADING_SELECTOR = ".about__heading, .contact__heading, .case-study__title, .region__name";

	function resetHeadingAnimations() {
		document.querySelectorAll<HTMLElement>(HEADING_SELECTOR).forEach((el) => {
			el.style.animation = "none";
			el.style.opacity = "0";
			el.getBoundingClientRect(); // force reflow
			el.style.animation = "";
			el.style.opacity = "";
		});
	}

	// Initial page load + every view-transition navigation
	document.addEventListener("astro:page-load", setupImageAnimations);
	document.addEventListener("astro:page-load", resetHeadingAnimations);

	function handlePendingScroll() {
		const target = sessionStorage.getItem("pendingScrollTo");
		if (target && window.location.pathname === "/") {
			sessionStorage.removeItem("pendingScrollTo");
			setTimeout(() => {
				const el = document.getElementById(target);
				if (el) {
					window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 64, behavior: "smooth" });
				}
			}, 400);
		}
	}

	document.addEventListener("astro:page-load", handlePendingScroll);
	document.addEventListener("astro:page-load", () => {
		sessionStorage.setItem("siteVisited", "true");
	});
</script>
