---
import { renderRichText } from "@storyblok/astro";
import PageLayout from "../layouts/PageLayout.astro";
import { getStory, sbImage } from "../lib/storyblok";

export const prerender = true;
import HeroCarousel from "../components/HeroCarousel.tsx";
import ContactForm from "../components/ContactForm.tsx";

const story = await getStory("contact");
const content = story?.content;

const heading = content?.heading ?? "CONTACT";
const heroImages: string[] = content?.hero_images
  ?.map((img: any) => sbImage(img.filename, 1200))
  .filter(Boolean) ?? [content?.hero_image?.filename].filter(Boolean).map((url: string) => sbImage(url, 1200));
const phone = content?.phone ?? "(415) 555-0198";
const phoneParts = phone.split("•").map((s: string) => s.trim());
const ownerName = phoneParts.length > 1 ? phoneParts[0] : null;
const phoneNumber = phoneParts.length > 1 ? phoneParts[1] : phoneParts[0];
const formNote =
  renderRichText(content?.form_note) ??
  "Please allow 1 - 2 business days for us to reply";
const hours =
  renderRichText(content?.hours) ??
  "Monday – Friday: 9:00 AM – 5:00 PM\nSaturday - Sunday: Closed";
---

<PageLayout
  title="Contact | Bicardo Builders Inc"
  description="Contact Bicardo Builders Inc to discuss your next custom home build, renovation, or addition project. We serve Marin County, San Francisco, and the East Bay."
>
  <div class="contact">
    <div class="contact__inner">
      <h1 class="contact__heading">{heading}</h1>
    </div>

    {
      heroImages.length > 0 ? (
        <div class="contact__hero">
          <div class="contact__carousel-inner">
            <HeroCarousel client:load images={heroImages} showDotNav={true} swipeable={true} />
          </div>
        </div>
      ) : (
        <div
          class="contact__hero contact__hero--placeholder"
          aria-hidden="true"
        />
      )
    }

    <div class="contact__inner">
      <p class="contact__phone">
        {ownerName && <span class="contact__phone-name">{ownerName}</span>}
        <a href={`tel:${phoneNumber.replace(/\D/g, "")}`}>{phoneNumber}</a>
      </p>

      <ContactForm client:load formNote={formNote} />

      <section class="contact__hours">
        <h2 class="contact__hours-heading">Hours of Operation</h2>
        <div class="contact__hours-list" set:html={hours}></div>
      </section>
    </div>
  </div>
</PageLayout>

<style>
  .contact {
    padding-bottom: 80px;
    grid-column: 1/-1;
  }

  .contact__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .contact__heading {
    animation: heading-fade-up 400ms ease-out both;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    margin: 48px 0 32px;
    text-align: center;
  }

  .contact__hero {
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
    margin-bottom: 48px;
  }

  .contact__hero--placeholder {
    height: clamp(280px, 45vw, 520px);
    background: #d1d5db;
  }

  .contact__carousel-inner {
    position: relative;
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
    height: clamp(130px, 29vw, 338px);
    overflow: hidden;
  }

  .contact__phone {
    font-family: "Manrope", sans-serif;
    text-align: center;
    font-size: 32px;
    font-weight: 300;
    margin: 0 0 8px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 4px 16px;
  }

  .contact__phone-name {
    color: var(--color-brand-primary);
  }

  .contact__phone a {
    color: var(--color-brand-primary);
    text-decoration: none;
  }

  .contact__phone a:hover {
    text-decoration: underline;
  }

  .contact__form-section {
    margin-bottom: 56px;
  }

  .contact__form-heading {
    font-family: "Manrope", sans-serif;
    text-align: center;
    margin-top: 48px;
    font-size: 32px;
    font-weight: 300;
    color: var(--color-brand-primary);
    letter-spacing: var(--tracking-1);
  }

  .contact__form-note {
    color: var(--color-text-primary);
    text-align: center;
    width: 100%;
    font-size: 16px;
    margin: 0 0 24px;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form__label {
    font-size: 12px;
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
  }

  .form__input,
  .form__textarea {
    border: 1px solid #c8dfe9;
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 16px;
    font-family: inherit;
    color: #111827;
    background: #e8f3fa;
    transition:
      border-color 140ms ease,
      background 140ms ease;
    width: 100%;
    box-sizing: border-box;
  }

  .form__input:focus,
  .form__textarea:focus {
    outline: none;
    border-color: #4892be;
    background: #d9ecf6;
    box-shadow: 0 0 0 3px rgba(72, 146, 190, 0.2);
  }

  .form__textarea {
    resize: vertical;
  }

  .form__submit-wrap {
    display: flex;
    justify-content: flex-start;
    align-self: center;
  }

  .btn-pill {
    display: inline-block;
    background: var(--color-brand-secondary);
    color: var(--color-surface-background);
    box-shadow: var(--shadow-image);
    text-decoration: none;
    font-family: "Manrope", sans-serif;
    font-size: 24px;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 12px 54px;
    border-radius: 50px;
    margin-top: 24px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition:
      background 140ms ease,
      transform 140ms ease;
  }

  .btn-pill:hover {
    background: #3a7aa8;
    transform: translateY(-1px);
  }

  .contact__hours-heading,
  .contact__hours-list {
    font-size: 24px;
    font-weight: 400;
    line-height: 34px;
    color: var(--color-text-primary);
    margin: 0 0 16px;
    text-align: center;
  }

  .contact__hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 768px) {
    .contact__phone {
      flex-direction: column;
      gap: 4px;
    }

    .contact__heading {
      margin: 32px 0 24px;
    }

    .contact__form-section,
    .contact__hours {
      text-align: center;
    }

    .contact__form-section {
      margin-bottom: 40px;
    }

    .form__submit-wrap {
      justify-content: center;
    }

    .contact__hours-list {
      display: inline-block;
      text-align: left;
    }
  }
</style>
