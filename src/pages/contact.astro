---
import PageLayout from '../layouts/PageLayout.astro';
import { getStory } from '../lib/storyblok';

const story = await getStory('contact');
const content = story?.content;

const heading = content?.heading ?? 'CONTACT';
const heroImage = content?.hero_image?.filename ?? null;
const phone = content?.phone ?? '(415) 555-0198';
const address = content?.address ?? '123 Builder Way\nSan Francisco, CA 94110';
const formNote = content?.form_note ?? 'Fill out the form below and we\'ll get back to you within one business day.';
const hours = content?.hours ?? 'Monday – Friday: 7:00 AM – 5:00 PM\nSaturday: By appointment\nSunday: Closed';
const addressLines: string[] = address.split('\n');
const hoursLines: string[] = hours.split('\n');
---

<PageLayout
  title="Contact | Bicardo Builders Inc"
  description="Contact Bicardo Builders Inc to discuss your custom home or renovation project."
>
  <div class="contact">
    <div class="contact__inner">
      <h1 class="contact__heading" transition:name="page-heading">{heading}</h1>
    </div>

    {heroImage ? (
      <div class="contact__hero">
        <img src={heroImage} alt="Bicardo Builders project" class="contact__hero-img" loading="lazy" />
      </div>
    ) : (
      <div class="contact__hero contact__hero--placeholder" aria-hidden="true"></div>
    )}

    <div class="contact__inner">
      <p class="contact__phone">
        <a href={`tel:${phone.replace(/\D/g, '')}`}>{phone}</a>
      </p>

      <address class="contact__address">
        {addressLines.map((line) => (
          <span>{line}<br /></span>
        ))}
      </address>

      <section class="contact__form-section">
        <h2 class="contact__form-heading">Send us a message</h2>
        <p class="contact__form-note">{formNote}</p>
        <form class="contact__form" method="post" action="#" novalidate>
          <div class="form__group">
            <label class="form__label" for="name">Name</label>
            <input class="form__input" id="name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="form__group">
            <label class="form__label" for="phone">Phone</label>
            <input class="form__input" id="phone" name="phone" type="tel" autocomplete="tel" />
          </div>
          <div class="form__group">
            <label class="form__label" for="email">Email</label>
            <input class="form__input" id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="form__group">
            <label class="form__label" for="message">Message</label>
            <textarea class="form__textarea" id="message" name="message" rows="5" required></textarea>
          </div>
          <div class="form__submit-wrap">
            <button class="btn-pill" type="submit">Send</button>
          </div>
        </form>
      </section>

      <section class="contact__hours">
        <h2 class="contact__hours-heading">Hours of Operation</h2>
        <ul class="contact__hours-list">
          {hoursLines.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
      </section>
    </div>
  </div>
</PageLayout>

<style>
  .contact {
    padding-bottom: 80px;
  }

  .contact__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .contact__heading {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #111827;
    margin: 48px 0 32px;
    text-align: center;
  }

  .contact__hero {
    width: 100%;
    margin-bottom: 48px;
  }

  .contact__hero-img {
    width: 100%;
    height: clamp(200px, 30vw, 360px);
    object-fit: cover;
    display: block;
  }

  .contact__hero--placeholder {
    height: clamp(200px, 30vw, 360px);
    background: #d1d5db;
  }

  .contact__phone {
    text-align: center;
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 600;
    margin: 0 0 8px;
  }

  .contact__phone a {
    color: #4892be;
    text-decoration: none;
  }

  .contact__phone a:hover {
    text-decoration: underline;
  }

  .contact__address {
    text-align: center;
    font-style: normal;
    color: #374151;
    font-size: 16px;
    line-height: 1.7;
    margin: 0 0 48px;
  }

  .contact__form-section {
    margin-bottom: 56px;
  }

  .contact__form-heading {
    font-size: 22px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 8px;
  }

  .contact__form-note {
    color: #374151;
    font-size: 15px;
    margin: 0 0 24px;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form__label {
    font-size: 14px;
    font-weight: 600;
    color: #374151;
    letter-spacing: 0.02em;
  }

  .form__input,
  .form__textarea {
    border: 1px solid #c8dfe9;
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 16px;
    font-family: inherit;
    color: #111827;
    background: #e8f3fa;
    transition: border-color 140ms ease, background 140ms ease;
    width: 100%;
    box-sizing: border-box;
  }

  .form__input:focus,
  .form__textarea:focus {
    outline: none;
    border-color: #4892be;
    background: #d9ecf6;
    box-shadow: 0 0 0 3px rgba(72, 146, 190, 0.2);
  }

  .form__textarea {
    resize: vertical;
  }

  .form__submit-wrap {
    display: flex;
    justify-content: flex-start;
  }

  .btn-pill {
    display: inline-block;
    background: #4892be;
    color: #fff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 12px 32px;
    border-radius: 24px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: background 140ms ease, transform 140ms ease;
  }

  .btn-pill:hover {
    background: #3a7aa8;
    transform: translateY(-1px);
  }

  .contact__hours-heading {
    font-size: 22px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 16px;
  }

  .contact__hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact__hours-list li {
    color: #374151;
    font-size: 16px;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .contact__heading {
      margin: 32px 0 24px;
    }

    .contact__form-section,
    .contact__hours {
      text-align: center;
    }

    .contact__form-section {
      margin-bottom: 40px;
    }

    .form__submit-wrap {
      justify-content: center;
    }

    .contact__hours-list {
      display: inline-block;
      text-align: left;
    }
  }
</style>
