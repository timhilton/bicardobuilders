---
import PageLayout from "../../layouts/PageLayout.astro";
import { getStory } from "../../lib/storyblok";
import { renderRichText } from "@storyblok/astro";

export const prerender = false;

const { slug } = Astro.params;
const story = await getStory(`portfolio/${slug}`);

if (!story) return Astro.redirect("/portfolio");

const content = story.content ?? {};
const body = content.body ?? [];
const project = body.find((b: any) => b.component === "project") ?? {};
const photoRows = project.images ?? [];

const title: string = project.title ?? story.name ?? "Project";
const services: string[] = project.services ?? [];
const rawHtml = project.description ? renderRichText(project.description) : null;
const descriptionHtml: string | null =
  rawHtml && rawHtml.replace(/<[^>]*>/g, "").trim() ? rawHtml : null;
---

<PageLayout
  title={`${title} | Bicardo Builders Inc`}
  description={title}
  activePath="/portfolio"
>
  <div class="case-study">
    <div class="case-study__inner">
      <h1 class="case-study__title">
        {title.toUpperCase()}
      </h1>

      {
        services.length > 0 && (
          <ul class="case-study__services">
            {services.map((s: string, i: number) => (
              <li class="service-pill" style={`animation-delay: ${i * 120}ms`}>{s}</li>
            ))}
          </ul>
        )
      }

      {
        descriptionHtml && (
          <div class="case-study__description" set:html={descriptionHtml} />
        )
      }

      {
        photoRows.length > 0 ? (
          <div class="photo-mosaic">
            {photoRows.map((blok: any) => {
              if (blok.component === "photo_row_pair") {
                const classes =
                  blok.layout?.[0] === "2-3" ? "" : "row-pair--reversed";
                return (
                  <div class={`row-pair ${classes}`}>
                    {blok.image_left?.filename && (
                      <div class="photo-container">
                        <img
                          src={blok.image_left.filename}
                          alt={blok.image_left.alt || title}
                          class="mosaic-img"
                          data-lightbox-src={blok.image_left.filename}
                          data-lightbox-alt={blok.image_left.alt || title}
                        />
                      </div>
                    )}
                    {blok.image_right?.filename && (
                      <div class="photo-container">
                        <img
                          src={blok.image_right.filename}
                          alt={blok.image_right.alt || title}
                          class="mosaic-img"
                          data-lightbox-src={blok.image_right.filename}
                          data-lightbox-alt={blok.image_right.alt || title}
                        />
                      </div>
                    )}
                  </div>
                );
              }

              if (blok.component === "photo_row_feature") {
                const reversed = blok.layout?.[0] === "feature-right";
                return (
                  <div
                    class:list={[
                      "row-feature",
                      reversed && "row-feature--reversed",
                    ]}
                  >
                    {blok.image_main?.filename && (
                      <div class="photo-container">
                        <img
                          src={blok.image_main.filename}
                          alt={blok.image_main.alt || title}
                          class="mosaic-img"
                          data-lightbox-src={blok.image_main.filename}
                          data-lightbox-alt={blok.image_main.alt || title}
                        />
                      </div>
                    )}
                    <div class="feature-stack">
                      {blok.image_top?.filename && (
                        <div class="photo-container">
                          <img
                            src={blok.image_top.filename}
                            alt={blok.image_top.alt || title}
                            class="mosaic-img"
                            data-lightbox-src={blok.image_top.filename}
                            data-lightbox-alt={blok.image_top.alt || title}
                          />
                        </div>
                      )}
                      {blok.image_bottom?.filename && (
                        <div class="photo-container">
                          <img
                            src={blok.image_bottom.filename}
                            alt={blok.image_bottom.alt || title}
                            class="mosaic-img"
                            data-lightbox-src={blok.image_bottom.filename}
                            data-lightbox-alt={blok.image_bottom.alt || title}
                          />
                        </div>
                      )}
                    </div>
                  </div>
                );
              }
            })}
          </div>
        ) : (
          <div class="photo-mosaic__empty">
            <p>Photos coming soon.</p>
          </div>
        )
      }

      <div class="case-study__back">
        <a href="/portfolio" class="btn-pill">← Back to Portfolio</a>
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lightbox-overlay"></div>
  <div id="lightbox" aria-modal="true" role="dialog" aria-label="Image viewer">
    <button id="lightbox-close" aria-label="Close">&times;</button>
    <button id="lightbox-prev" aria-label="Previous"></button>
    <div id="lightbox-img-wrap">
      <img id="lightbox-img" src="" alt="" />
    </div>
    <button id="lightbox-next" aria-label="Next"></button>
  </div>
</PageLayout>

<style>
  .case-study {
    padding-bottom: 80px;
    grid-column: 1 / -1;
  }

  .case-study__inner {
    /* max-width: 960px; */
    margin: 0 auto;
  }

  @keyframes title-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .case-study__title {
    animation: heading-fade-up 400ms ease-out both;
    font-size: clamp(24px, 4vw, 38px);
    font-family: var(--font-manrope);
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--color-brand-primary);
    margin: 48px 0 8px;
    animation: title-in 900ms ease-in-out both;
  }

  .case-study__services {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0 0 32px;
    padding: 0;
  }

  @keyframes pill-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .service-pill {
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-brand-secondary);
    border: 1px solid var(--color-brand-secondary);
    border-radius: 24px;
    padding: 4px 16px;
    opacity: 0;
    animation: pill-in 1000ms ease-in-out forwards;
  }

  .case-study__description {
    color: var(--color-text-primary);
    font-size: 16px;
    font-weight: 100;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .case-study__description :global(p) {
    margin: 0 0 16px;
  }

  .photo-mosaic {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 48px;
  }

  .row-pair {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 12px;

    .photo-container {
      overflow: hidden;

      &:first-child {
        aspect-ratio: 1/1;
      }

      &:last-child {
        aspect-ratio: 3/2;
      }

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        box-shadow: var(--shadow-image);
      }
    }
  }

  .row-pair.row-pair--reversed {
    grid-template-columns: 3fr 2fr;

    .photo-container {
      overflow: hidden;

      &:last-child {
        aspect-ratio: 1/1;
      }

      &:first-child {
        aspect-ratio: 3/2;
      }
    }
  }

  .row-feature,
  .row-feature--reversed {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 12px;
    align-items: stretch;

    .photo-container {
      aspect-ratio: 1/1;
      overflow: hidden;
      grid-column: 1 / span 7;

      image: {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        box-shadow: var(--shadow-image);
      }
    }
  }

  .row-feature--reversed .photo-container {
    grid-row: 1;
    grid-column: 6 / -1;
    min-width: 0;
    gap: 12px;
  }

  .feature-stack {
    display: grid;
    grid-column: 8 / -1;
    gap: 24px;
    height: 100%;
    align-items: stretch;
    min-width: 0;
    overflow: hidden;

    .photo-container {
      grid-row: unset;
      aspect-ratio: 3/2;
      overflow: hidden;
      min-width: 0;

      image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        box-shadow: var(--shadow-image);
      }
    }
  }

  .row-feature--reversed .feature-stack {
    grid-row: 1;
    grid-column: 1 / span 5;
    align-items: stretch;
    overflow: hidden;

    .photo-container:first-child {
      grid-row: 1;
    }
    .photo-container:last-child {
      grid-row: 2;
    }
  }

  .mosaic-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    cursor: pointer;
    transition: opacity 140ms ease;
    box-shadow: var(--shadow-image);
  }

  :global(.mosaic-img.img-animate) {
    animation-duration: 900ms;
    animation-timing-function: ease-in-out;
  }

  .mosaic-img:hover {
    opacity: 0.85;
  }

  .photo-mosaic__empty {
    text-align: center;
    color: #6b7280;
    padding: 64px 0;
    margin-bottom: 48px;
  }

  .case-study__back {
    display: flex;
    justify-content: flex-start;
  }

  .btn-pill {
    font-size: 15px;
    padding: 14px 42px 15px;
  }

  /* ── Lightbox ── */
  #lightbox-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(46, 46, 47, 0.6);
    backdrop-filter: blur(4px);
    z-index: 10000;
    cursor: pointer;
  }

  #lightbox-overlay.is-open {
    display: block;
  }

  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10001;
    align-items: center;
    justify-content: center;
    padding: 24px 80px;
    box-sizing: border-box;
    pointer-events: none;
  }

  #lightbox.is-open {
    display: flex;
  }

  #lightbox-img-wrap {
    max-width: 900px;
    max-height: 90vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
  }

  #lightbox-img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.6);
    display: block;
  }

  #lightbox-close {
    position: fixed;
    top: 16px;
    right: 24px;
    background: none;
    border: none;
    color: #fff;
    font-size: 44px;
    line-height: 1;
    cursor: pointer;
    opacity: 0.75;
    transition: opacity 140ms ease;
    pointer-events: auto;
    z-index: 10002;
  }

  #lightbox-close:hover {
    opacity: 1;
  }

  #lightbox-prev,
  #lightbox-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    font-size: 36px;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 140ms ease;
    pointer-events: auto;
    z-index: 10002;
  }

  #lightbox-prev {
    inset-inline-start: 5%;

    &::after {
      content: "<";
      position: absolute;
      inset-inline-start: -2px;
      width: 100%;
      height: 100%;
      font-family: "Open Sans", sans-serif;
      font-size: 36px;
      font-weight: 100;
      opacity: 1;
      animation: pulse 1.5s infinite;
    }
  }
  #lightbox-next {
    inset-inline-end: 5%;

    &::after {
      content: ">";
      position: absolute;
      inset-inline-end: -2px;
      width: 100%;
      height: 100%;
      font-family: "Open Sans", sans-serif;
      font-size: 36px;
      font-weight: 100;
      opacity: 1;
      animation: pulse 1.5s infinite;
    }
  }

  #lightbox-prev:hover,
  #lightbox-next:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 768px) {
    .case-study__inner {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
    }

    .case-study__title,
    .case-study__services,
    .case-study__description {
      grid-column: 2 / span 10;
    }

    .case-study__description {
      margin-top: 24px;
    }

    .case-study__back {
      grid-column: 2 / span 10;
      justify-content: center;
    }

    .photo-mosaic,
    .photo-mosaic__empty {
      grid-column: 1 / -1;
    }

    .case-study__description {
      margin-bottom: 0;
    }

    .case-study__title {
      margin-top: 24px;
      margin-bottom: 12px;
    }
    .case-study__services {
      margin-bottom: 0;
    }

    .photo-mosaic {
      display: flex;
      gap: 12px;
      margin-top: 24px;
      margin-bottom: 24px;
    }

    .row-pair,
    .row-feature {
      display: flex;
      flex-direction: column;
      gap: 12px;

      .photo-container {
        aspect-ratio: unset;
      }
    }

    .row-feature--reversed .feature-stack {
      display: flex;
      flex-direction: column;
    }

    .feature-stack {
      display: flex;
      flex-direction: column;
    }

    .mosaic-img {
      aspect-ratio: 3/2;
      height: auto;
    }

    #lightbox {
      padding: 24px 12px;
    }

    #lightbox-prev {
      left: 6px;
    }
    #lightbox-next {
      right: 6px;
    }
  }
</style>

<script>
  function initLightbox() {
    const lightbox = document.getElementById("lightbox")!;
    const overlay = document.getElementById("lightbox-overlay")!;
    const img = document.getElementById("lightbox-img") as HTMLImageElement;
    const closeBtn = document.getElementById("lightbox-close")!;
    const prevBtn = document.getElementById("lightbox-prev")!;
    const nextBtn = document.getElementById("lightbox-next")!;

    const images = Array.from(
      document.querySelectorAll<HTMLImageElement>(
        ".mosaic-img[data-lightbox-src]",
      ),
    ).map((el) => ({
      src: el.dataset.lightboxSrc!,
      alt: el.dataset.lightboxAlt ?? "",
    }));

    let current = 0;

    function open(index: number) {
      current = index;
      img.src = images[current].src;
      img.alt = images[current].alt;
      lightbox.classList.add("is-open");
      overlay.classList.add("is-open");
      document.body.style.overflow = "hidden";
      document.body.classList.add("lightbox-open");
    }

    function close() {
      lightbox.classList.remove("is-open");
      overlay.classList.remove("is-open");
      document.body.style.overflow = "";
      document.body.classList.remove("lightbox-open");
    }

    function prev() {
      current = (current - 1 + images.length) % images.length;
      img.src = images[current].src;
      img.alt = images[current].alt;
    }

    function next() {
      current = (current + 1) % images.length;
      img.src = images[current].src;
      img.alt = images[current].alt;
    }

    document
      .querySelectorAll<HTMLImageElement>(".mosaic-img[data-lightbox-src]")
      .forEach((el, i) => {
        el.addEventListener("click", () => open(i));
      });

    closeBtn.addEventListener("click", close);
    overlay.addEventListener("click", close);
    prevBtn.addEventListener("click", prev);
    nextBtn.addEventListener("click", next);

    document.addEventListener("keydown", (e) => {
      if (!lightbox.classList.contains("is-open")) return;
      if (e.key === "ArrowLeft") prev();
      if (e.key === "ArrowRight") next();
      if (e.key === "Escape") close();
    });

    let touchStartX: number | null = null;
    lightbox.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    lightbox.addEventListener("touchend", (e) => {
      if (touchStartX === null) return;
      const delta = touchStartX - e.changedTouches[0].clientX;
      touchStartX = null;
      if (Math.abs(delta) < 50) return;
      delta > 0 ? next() : prev();
    }, { passive: true });
  }

  document.addEventListener("astro:page-load", initLightbox);
</script>
