---
import PageLayout from "../layouts/PageLayout.astro";
import { getStory } from "../lib/storyblok";
import { renderRichText } from "@storyblok/astro";
import HeroCarousel from "../components/HeroCarousel.tsx";

const story = await getStory("about");
const content = story?.content;

const heading = content?.heading ?? "ABOUT US";
const heroImages: string[] =
  content?.hero_images?.map((img: any) => img.filename).filter(Boolean) ??
  [content?.hero_image?.filename].filter(Boolean);
const bodyHtml = content?.body ? renderRichText(content.body) : null;
const ctaLabel = content?.cta_label;
const ctaUrl = content?.cta_url;
---

<PageLayout
  title="About | Bicardo Builders Inc"
  description="Learn about Bicardo Builders Inc, a family-owned general contracting firm with over 20 years of experience in the San Francisco Bay Area."
>
  <div class="about">
    <div class="about__inner">
      <h1 class="about__heading">{heading}</h1>
    </div>

    {
      heroImages.length > 0 ? (
        <div class="about__hero">
          <HeroCarousel
            client:visible
            images={heroImages}
            showDotNav={true}
            swipeable={true}
          />
        </div>
      ) : (
        <div class="about__hero about__hero--placeholder" aria-hidden="true" />
      )
    }

    <div class="about__inner">
      <div class="about__body" set:html={bodyHtml} />
      <div class="about__cta-wrap">
        <a href="/contact" class="btn-pill">{ctaLabel}</a>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .about {
    padding-bottom: 80px;
    grid-column: 1/-1;
  }

  .about__inner {
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
  }

  .about__heading {
    animation: heading-fade-up 400ms ease-out both;
    font-family: var(--font-manrope);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    margin: 48px 0 32px;
    grid-column: 1/-1;
  }

  .about__hero {
    position: relative;
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
    height: clamp(280px, 45vw, 520px);
    overflow: hidden;
    margin-bottom: 48px;
  }

  .about__hero--placeholder {
    background: #d1d5db;
  }

  @media (max-width: 768px) {
    .about__heading {
      margin: 32px 0 24px;
    }

    .about__hero {
      margin-bottom: 24px;
    }

    .about__inner {
      width: calc(10 / 12 * 100%);
      margin-inline: auto;
    }
  }

  .about__body {
    color: var(--color-text-primary);
    font-size: var(--text-md);
    font-weight: 100;
    letter-spacing: 0.025em;
    line-height: 34px;
    grid-column: 1/-1;

    p {
      margin-bottom: 12px;
    }
  }

  .about__cta-wrap {
    margin-top: 48px;
    display: flex;
    justify-content: center;
    place-items: center;
    grid-column: 1/-1;
  }
</style>
