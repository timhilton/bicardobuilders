---
import PageLayout from '../layouts/PageLayout.astro';
import { getStory } from '../lib/storyblok';
import { renderRichText } from '@storyblok/astro';

const story = await getStory('about');
const content = story?.content;

const heading = content?.heading ?? 'ABOUT US';
const heroImage = content?.hero_image?.filename ?? null;
const bodyHtml = content?.body ? renderRichText(content.body) : null;
const ctaLabel = content?.cta_label ?? 'GET IN TOUCH';
const ctaUrl = content?.cta_url ?? '/contact';

const fallbackBody = `
  <p>Bicardo Builders Inc. is a family-owned general contracting firm with over 20 years of experience in the San Francisco Bay Area. We specialize in custom homes, whole-home renovations, and high-end additions — delivering exceptional results through skilled craftsmanship and deep client collaboration.</p>
  <p>Our team brings together decades of hands-on expertise in carpentry, concrete, framing, and finish work. We self-perform much of our own labor, which means tighter quality control, better communication, and accountability at every stage of your project.</p>
  <p>We believe a great build starts with a great relationship. From the first consultation to the final walkthrough, we stay in close contact with our clients — listening carefully, problem-solving creatively, and always keeping sight of what matters most: a home you'll love for years to come.</p>
`;
---

<PageLayout
  title="About | Bicardo Builders Inc"
  description="Learn about Bicardo Builders Inc, a family-owned general contracting firm with over 20 years of experience in the San Francisco Bay Area."
>
  <div class="about">
    <div class="about__inner">
      <h1 class="about__heading" transition:name="page-heading">{heading}</h1>
    </div>

    {heroImage ? (
      <div class="about__hero">
        <img src={heroImage} alt="Bicardo Builders project" class="about__hero-img" loading="lazy" />
      </div>
    ) : (
      <div class="about__hero about__hero--placeholder" aria-hidden="true"></div>
    )}

    <div class="about__inner">
      <div class="about__body" set:html={bodyHtml ?? fallbackBody} />
      <div class="about__cta-wrap">
        <a href={ctaUrl} class="btn-pill">{ctaLabel}</a>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .about {
    padding-bottom: 80px;
  }

  .about__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .about__heading {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #111827;
    margin: 48px 0 32px;
  }

  .about__hero {
    width: 100%;
    margin-bottom: 48px;
  }

  .about__hero-img {
    width: 100%;
    height: clamp(280px, 45vw, 520px);
    object-fit: cover;
    display: block;
  }

  .about__hero--placeholder {
    height: clamp(280px, 45vw, 520px);
    background: #d1d5db;
  }

  @media (max-width: 768px) {
    .about__hero,
    .about__hero--placeholder {
      display: none;
    }

    .about__heading {
      margin: 32px 0 24px;
    }
  }

  .about__body {
    color: #374151;
    font-size: 16px;
    line-height: 1.7;
  }

  .about__body :global(p) {
    margin: 0 0 24px;
  }

  .about__cta-wrap {
    margin-top: 48px;
    display: flex;
    justify-content: center;
  }

  .btn-pill {
    display: inline-block;
    background: #4892be;
    color: #fff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 12px 32px;
    border-radius: 24px;
    transition: background 140ms ease, transform 140ms ease;
  }

  .btn-pill:hover {
    background: #3a7aa8;
    transform: translateY(-1px);
  }
</style>
