---
import PageLayout from '../layouts/PageLayout.astro';
import { getStory } from '../lib/storyblok';
import { renderRichText } from '@storyblok/astro';

const story = await getStory('services');
const content = story?.content;

const heading = content?.heading ?? 'SERVICES';
const introHtml = content?.intro ? renderRichText(content.intro) : null;
const topImage = content?.top_image?.filename ?? null;
const servicesIntro = content?.services_intro ?? 'Our services include:';
const serviceItemsRaw: string = content?.service_items ?? '';
const serviceItems: string[] = serviceItemsRaw
  ? serviceItemsRaw.split('\n').map((s: string) => s.trim()).filter(Boolean)
  : [
      'Custom home construction',
      'Whole-home renovations',
      'Kitchen & bathroom remodels',
      'Additions & ADUs',
      'Decks, patios & outdoor structures',
      'Framing & structural work',
      'Finish carpentry & millwork',
      'Project management & permitting',
    ];
const bottomImage = content?.bottom_image?.filename ?? null;
const outro = content?.outro ?? 'Every project is unique. We work closely with architects, designers, and homeowners to bring your vision to life — on time and on budget. Reach out to discuss your project.';
const ctaLabel = content?.cta_label ?? 'GET IN TOUCH';
const ctaUrl = content?.cta_url ?? '/contact';

const fallbackIntro = `<p>We offer a full range of general contracting services for residential clients throughout the San Francisco Bay Area. Whether you're building from the ground up or updating a beloved space, our experienced team handles every phase of the process with care and precision.</p>`;
---

<PageLayout
  title="Services | Bicardo Builders Inc"
  description="General contracting services including custom homes, renovations, additions, and more from Bicardo Builders Inc."
>
  <div class="services">
    <div class="services__inner">
      <h1 class="services__heading" transition:name="page-heading">{heading}</h1>

      <div class="services__row">
        <div class="services__intro" set:html={introHtml ?? fallbackIntro} />
        <div class="services__top-img-wrap">
          {topImage ? (
            <img src={topImage} alt="Construction project" class="services__img" loading="lazy" />
          ) : (
            <div class="services__img-placeholder" aria-hidden="true"></div>
          )}
        </div>
      </div>

      <div class="services__row services__row--reverse">
        <div class="services__bottom-img-wrap">
          {bottomImage ? (
            <img src={bottomImage} alt="Construction detail" class="services__img" loading="lazy" />
          ) : (
            <div class="services__img-placeholder" aria-hidden="true"></div>
          )}
        </div>
        <div class="services__list-col">
          <p class="services__list-intro">{servicesIntro}</p>
          <ul class="services__list">
            {serviceItems.map((item) => (
              <li class="services__list-item">{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <p class="services__outro">{outro}</p>

      <div class="services__cta-wrap">
        <a href={ctaUrl} class="btn-pill">{ctaLabel}</a>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .services {
    padding-bottom: 80px;
  }

  .services__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .services__heading {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #111827;
    margin: 48px 0 40px;
  }

  .services__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    margin-bottom: 56px;
  }

  .services__row--reverse {
    direction: ltr;
  }

  .services__intro {
    color: #374151;
    font-size: 16px;
    line-height: 1.7;
  }

  .services__intro :global(p) {
    margin: 0 0 16px;
  }

  .services__img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    display: block;
    border-radius: 4px;
  }

  .services__img-placeholder {
    width: 100%;
    height: 320px;
    background: #d1d5db;
    border-radius: 4px;
  }

  .services__list-intro {
    font-size: 16px;
    font-weight: 600;
    color: #111827;
    margin: 0 0 16px;
  }

  .services__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .services__list-item {
    color: #374151;
    font-size: 16px;
    line-height: 1.7;
    padding: 6px 0 6px 20px;
    position: relative;
  }

  .services__list-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4892be;
  }

  .services__outro {
    color: #374151;
    font-size: 16px;
    line-height: 1.7;
    margin: 0 0 48px;
  }

  .services__cta-wrap {
    display: flex;
    justify-content: center;
  }

  .btn-pill {
    display: inline-block;
    background: #4892be;
    color: #fff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 12px 32px;
    border-radius: 24px;
    transition: background 140ms ease, transform 140ms ease;
  }

  .btn-pill:hover {
    background: #3a7aa8;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .services__heading {
      margin: 32px 0 28px;
    }

    .services__row {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 36px;
    }

    /* Row 1: intro text first, image below */
    /* Row 2: list first, image below */
    .services__row--reverse .services__list-col {
      order: -1;
    }
  }
</style>
