---
import PageLayout from "../layouts/PageLayout.astro";
import { getStory } from "../lib/storyblok";
import { renderRichText } from "@storyblok/astro";

const story = await getStory("services");
const content = story?.content;
const servicesBlok = content?.body[0];

// Safe rendering - only call renderRichText if content exists
const servicesCtaBlok = servicesBlok?.cta_blok
    ? renderRichText(servicesBlok.cta_blok)
    : "";
const servicesIntro = servicesBlok?.services_intro
    ? renderRichText(servicesBlok.services_intro)
    : "";

const serviceItems: string[] =
    servicesBlok?.service_items
        ?.split("\n")
        .map((s: string) => s.trim())
        .filter(Boolean) ?? [];
const servicesPhoto = servicesBlok?.services_image?.filename;
---

<PageLayout title="">
    <section class="services">
        <h2 class="services__heading">Services</h2>
        <div class="services__copy" set:html={servicesIntro} />
        <div class="services__image">
            <img
                src={servicesPhoto}
                alt="service photo"
                class="services__image"
                loading="eager"
                decoding="async"
            />
        </div>
        <div class="services__right">
            <ul class="services__list">
                {
                    serviceItems.map((item) => (
                        <li class="services__list-item">{item}</li>
                    ))
                }
            </ul>
            <div class="services__cta-blok" set:html={servicesCtaBlok} />
        </div>
    </section>
</PageLayout>

<style>
    .services {
        grid-column: 1 / -1;
        padding: 48px 0;
        display: grid;
        grid-template-columns: 5fr 48px 6fr;
        grid-template-areas:
            "heading . right"
            "copy    . right"
            "image   . right";
        position: relative;

        &::after {
            content: "";
            position: absolute;
            bottom: 0;
            width: 100vw;
            margin-inline-start: calc(50% - 50vw);
            border-bottom: 1px solid var(--color-brand-secondary);
        }
    }

    .services__copy {
        color: var(--color-text-secondary);
        font-size: 16px;
        letter-spacing: 0.025em;
        margin: 0;

        p {
            margin-top: 0;
        }
    }

    .services__heading {
        font-weight: 300;
        font-family: var(--font-manrope);
        color: var(--color-brand-primary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: var(--text-xl);
        grid-area: heading;
        margin: 0;
    }

    .services__copy,
    .services__cta-blok {
        color: var(--color-text-primary);
        font-size: var(--text-md);
        font-weight: 100;
        line-height: 1.7;
    }

    .services__copy {
        grid-area: copy;
    }

    .services__right {
        grid-area: right;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .services__cta-blok {
        margin-top: 24px;
    }

    .services__image {
        grid-area: image;
    }
    .services__image img {
        width: 100%;
        height: auto;
        object-fit: cover;
        box-shadow: var(--shadow-image);
    }
    .services__list {
        font-weight: 100;
        margin: 0;
        padding: 0;
        list-style: none;
        width: 100%;
    }
    .services__list-item {
        padding: 16px 24px;
        border-bottom: 1px solid var(--color-brand-secondary);
        font-size: var(--text-sm);
        line-height: 1.7;
        color: var(--color-text-primary);
        box-shadow: var(--shadow-image);
        text-transform: uppercase;
        width: 100%;
        box-sizing: border-box;
        transition: transform 350ms ease-in-out;

        &:hover {
            transform: translateX(-16px);
        }
    }

    .contact-cta {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .contact-cta__heading {
        font-weight: 100;
        font-family: var(--font-manrope);
        color: var(--color-brand-primary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: var(--text-xl);
    }
</style>
