---
import PageLayout from "../layouts/PageLayout.astro";
import { getStories, sbImage } from "../lib/storyblok";

export const prerender = true;

const projectStories = await getStories({ starts_with: "portfolio/" });

// Filter out the index story itself
const projects = projectStories.filter((s: any) => !s.is_startpage);

const regionOrder = ["Marin County", "San Francisco", "East Bay", "Sonoma"];

const regions = projects
  .reduce((acc: any[], project: any) => {
    const body = project?.content?.body ?? [];
    const p = body.find((b: any) => b.component === "project");
    const regionName = p?.region || "Our Work";
    const existing = acc.find((r) => r.name === regionName);
    if (existing) {
      existing.projects.push(project);
    } else {
      acc.push({ name: regionName, projects: [project] });
    }
    return acc;
  }, [])
  .map((region: any) => ({
    ...region,
    projects: region.projects.sort(
      (a: any, b: any) =>
        new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime(),
    ),
  }))
  .sort((a: any, b: any) => {
    const ai = regionOrder.indexOf(a.name);
    const bi = regionOrder.indexOf(b.name);
    if (ai === -1) return 1;
    if (bi === -1) return -1;
    return ai - bi;
  });

const useFallback = regions.length === 0;

const fallbackProjects = [
  { title: "Russian Hill Residence", slug: "russian-hill" },
  { title: "Pacific Heights Remodel", slug: "pacific-heights" },
  { title: "Noe Valley Addition", slug: "noe-valley" },
  { title: "Cole Valley Kitchen", slug: "cole-valley" },
];

const fallbackRegions = [
  {
    name: "Marin County",
    projects: fallbackProjects.map((p) => ({
      content: { title: p.title },
      slug: p.slug,
    })),
  },
];

function layoutClass(count: number): string {
  if (count >= 4) return "layout-full";
  if (count === 3) return "layout-3";
  if (count === 2) return "layout-2";
  return "layout-1";
}

function getSlug(project: any): string {
  return "/" + (project.full_slug ?? project.slug ?? "");
}

function getThumbnail(project: any): string | null {
  const body = project?.content?.body ?? [];
  const p = body.find((b: any) => b.component === "project");
  return p?.thumbnail?.filename ?? null;
}

function getTitle(project: any): string {
  const body = project?.content?.body ?? [];
  const p = body.find((b: any) => b.component === "project");
  return p?.title ?? project?.name ?? "Project";
}
---

<PageLayout
  title="Portfolio | Bicardo Builders Inc"
  description="Explore our portfolio of custom homes, renovations, and additions across the San Francisco Bay Area."
>
  <div class="portfolio">
    <div class="portfolio__inner">
      <h1 class="portfolio__heading visually-hidden">PORTFOLIO</h1>

      {
        useFallback ? (
          <div class="region">
            <h2 class="region__name">
              {fallbackRegions[0]?.name ?? "Our Work"}
            </h2>
            <div class="project-grid layout-full">
              {fallbackProjects.map((p, i) => (
                <a
                  href={`/portfolio/${p.slug}`}
                  class:list={["project-card", i === 0 && "hero"]}
                >
                  <div class="img-wrap">
                    <div class="img-placeholder" aria-hidden="true" />
                  </div>
                  <p class="card-title">{p.title}</p>
                </a>
              ))}
            </div>
          </div>
        ) : (
          (() => {
            const output = [];
            let i = 0;
            while (i < regions.length) {
              const region = regions[i];
              const next = regions[i + 1];
              const count = region.projects.length;
              const nextCount = next?.projects.length;

              if (count === 1 && nextCount === 1) {
                output.push(
                  <div class="region-pair">
                    <div class="region">
                      <h2 class="region__name">{region.name.toUpperCase()}</h2>
                      <div class="project-grid layout-1">
                        {region.projects.map((project: any) => {
                          const thumb = getThumbnail(project);
                          const title = getTitle(project);
                          return (
                            <a href={getSlug(project)} class="project-card">
                              <div class="img-wrap">
                                {thumb ? (
                                  <img
                                    src={thumb}
                                    alt={title}
                                    class="img"
                                    loading="lazy"
                                  />
                                ) : (
                                  <div
                                    class="img-placeholder"
                                    aria-hidden="true"
                                  />
                                )}
                              </div>
                              <p class="card-title">{title}</p>
                            </a>
                          );
                        })}
                      </div>
                    </div>
                    <div class="region">
                      <h2 class="region__name">{next.name.toUpperCase()}</h2>
                      <div class="project-grid layout-1">
                        {next.projects.map((project: any) => {
                          const thumb = getThumbnail(project);
                          const title = getTitle(project);
                          return (
                            <a href={getSlug(project)} class="project-card">
                              <div class="img-wrap">
                                {thumb ? (
                                  <img
                                    src={thumb}
                                    alt={title}
                                    class="img"
                                    loading="lazy"
                                  />
                                ) : (
                                  <div
                                    class="img-placeholder"
                                    aria-hidden="true"
                                  />
                                )}
                              </div>
                              <p class="card-title">{title}</p>
                            </a>
                          );
                        })}
                      </div>
                    </div>
                  </div>,
                );
                i += 2;
              } else {
                output.push(
                  <div class="region">
                    <h2 class="region__name">{region.name.toUpperCase()}</h2>
                    {count > 0 && (
                      <div class:list={["project-grid", layoutClass(count)]}>
                        {region.projects.map((project: any, j: number) => {
                          const thumb = getThumbnail(project);
                          const title = getTitle(project);
                          const isHero = j === 0 && count >= 4;
                          return (
                            <a
                              href={getSlug(project)}
                              class:list={["project-card", isHero && "hero"]}
                            >
                              <div class="img-wrap">
                                {thumb ? (
                                  <img
                                    src={sbImage(thumb, 800)}
                                    alt={title}
                                    class="img"
                                    loading={j === 0 ? "eager" : "lazy"}
                                  />
                                ) : (
                                  <div
                                    class="img-placeholder"
                                    aria-hidden="true"
                                  />
                                )}
                              </div>
                              <p class="card-title">{title}</p>
                            </a>
                          );
                        })}
                      </div>
                    )}
                  </div>,
                );
                i += 1;
              }
            }
            return output;
          })()
        )
      }
    </div>
  </div>
</PageLayout>

<style>
  .portfolio {
    margin-top: 48px;
    padding-bottom: 80px;
    grid-column: auto/span 12;
    width: 100%;
  }

  .portfolio__inner {
    max-width: 100%;
    margin: 0 auto;
  }

  .region {
    margin-bottom: 64px;
    width: 100%;
  }

  .region-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 64px;
  }

  .region-pair .region {
    margin-bottom: 0;
  }

  .region__name {
    animation: heading-fade-up 400ms ease-out both;
    font-size: 40px;
    font-family: var(--font-manrope);
    font-weight: 200;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    letter-spacing: 0.1em;
    margin: 0 0 16px;
  }

  /* ===== BASE CARD ===== */
  .project-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background-color: transparent;
  }

  .project-card:hover .img {
    transform: scale(1.05);
  }

  .img-wrap {
    width: 100%;
    overflow: hidden;
    box-shadow: var(--shadow-image);
  }

  .img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 350ms ease-in-out;
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
  }

  .card-title {
    margin: 16px 0 0;
    font-size: 14px;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--color-brand-secondary);
    letter-spacing: 0.08em;
  }

  /* ===== LAYOUT: FULL (4+) ===== */
  .layout-full {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .layout-full .hero {
    grid-column: 1 / -1;
  }

  .layout-full .hero .img-wrap {
    aspect-ratio: 16/9;
  }

  .layout-full .project-card:not(.hero) .img-wrap {
    aspect-ratio: 1/1;
  }

  /* ===== LAYOUT: 3 ===== */
  .layout-3 {
    display: grid;
    grid-template-columns: 4fr 3fr;
    gap: 24px;
  }

  .layout-3 .project-card:nth-child(1) {
    grid-row: span 2;
    display: flex;
    flex-direction: column;
  }

  .layout-3 .project-card:nth-child(1) .img-wrap {
    flex: 1;
    min-height: 0;
    position: relative;
  }

  .layout-3 .project-card:nth-child(1) .img-wrap .img,
  .layout-3 .project-card:nth-child(1) .img-wrap .img-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .layout-3 .project-card:nth-child(2) .img-wrap,
  .layout-3 .project-card:nth-child(3) .img-wrap {
    aspect-ratio: 3/2;
  }

  /* ===== LAYOUT: 2 ===== */
  .layout-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .layout-2 .project-card .img-wrap {
    aspect-ratio: 1/1;
  }

  /* ===== LAYOUT: 1 ===== */
  .layout-1 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .layout-1 .project-card .img-wrap {
    aspect-ratio: 1/1;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .layout-full,
    .layout-3,
    .layout-2,
    .layout-1 {
      grid-template-columns: 1fr;
    }

    .region-pair {
      grid-template-columns: 1fr;
    }

    .region {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
    }
    .region__name {
      grid-column: 2 / span 10;
    }

    .project-grid {
      grid-column: 1 / -1;
    }

    .layout-full .hero,
    .layout-3 .project-card:nth-child(1) {
      grid-column: 1;
      grid-row: auto;
      /* display: block; */
    }

    .layout-3 .project-card:nth-child(1) .img-wrap {
      flex: unset;
      position: static;
      aspect-ratio: 3/2;
    }

    .layout-3 .project-card:nth-child(1) .img-wrap .img,
    .layout-3 .project-card:nth-child(1) .img-wrap .img-placeholder {
      position: static;
      width: 100%;
      height: auto;
      aspect-ratio: 3/2;
      object-fit: cover;
    }

    .project-card {
      display: grid !important;
      grid-template-columns: repeat(12, 1fr);
    }

    .project-card--hidden {
      display: none !important;
    }

    .project-card .img-wrap {
      grid-column: 1/-1;
      aspect-ratio: 3/2 !important;
      height: auto !important;
    }

    .card-title {
      grid-column: 2 / span 10;
    }
  }
</style>

<style is:global>
  .view-more-btn {
    display: none;
  }

  @media (max-width: 768px) {
    .view-more-btn {
      display: flex;
      grid-column: 1/-1;
      margin: 16px auto 0;
      background: var(--color-brand-secondary);
      color: #fff;
      border: none;
      border-radius: 24px;
      padding: 12px 36px;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: inherit;
      transition:
        background var(--transition-fast),
        transform var(--transition-fast);
    }

    .view-more-btn:hover {
      background: var(--color-brand-secondary-hover);
      transform: translateY(-1px);
    }
  }
</style>

<script>
  function setupPortfolioMobile() {
    if (window.innerWidth > 768) return;

    document.querySelectorAll<HTMLElement>(".region").forEach((region) => {
      region.querySelectorAll(".view-more-btn").forEach((b) => b.remove());

      const cards = Array.from(
        region.querySelectorAll<HTMLElement>(".project-card"),
      );
      if (cards.length <= 2) return;

      cards.forEach((card, i) => {
        card.classList.toggle("project-card--hidden", i >= 2);
      });

      const btn = document.createElement("button");
      btn.className = "view-more-btn";
      btn.textContent = "VIEW MORE";
      region.querySelector(".project-grid")?.after(btn);

      btn.addEventListener("click", () => {
        cards.forEach((card) => card.classList.remove("project-card--hidden"));
        btn.remove();
      });
    });
  }

  document.addEventListener("astro:page-load", setupPortfolioMobile);
</script>
