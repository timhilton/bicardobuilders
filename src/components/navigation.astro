---
import Logo from "./Logo.astro";

interface LinkItem {
    label: string;
    href: string;
}

interface Props {
    links?: LinkItem[];
    activePath?: string;
    align?: "left" | "center" | "right";
}

const {
    links = [
        { label: "ABOUT", href: "/about" },
        { label: "SERVICES", href: "/services"},
        { label: "PORTFOLIO", href: "/portfolio" },
        { label: "CONTACT", href: "/contact" },
    ],
    activePath = "",
    align = "center",
} = Astro.props;

const justify =
    align === "left" ? "flex-start" : align === "right" ? "flex-end" : "center";

const isActive = (href: string) =>
    activePath === href || (href !== "/" && activePath.startsWith(href + "/"));
---

<nav class="nav" aria-label="Primary">
    <div class="nav__inner">
        <a href="/" class="nav__logo">
            <Logo
                width={123}
                height={42}
                color="#2b5eba"
                transition:name="logo"
            />
        </a>

        <button
            class="nav__toggle"
            aria-label="Open navigation"
            aria-expanded="false"
            aria-controls="nav-menu"
        >
            <span></span>
            <span></span>
            <span></span>
        </button>

        <ul
            id="nav-menu"
            class="nav__list"
            style={`justify-content:${justify}`}
        >
            {
                links.map((item) => (
                    <li class="nav__item">
                        <a
                            class:list={[
                                "nav__link",
                                isActive(item.href) && "nav__link--active",
                            ]}
                            href={item.href}
                            aria-current={
                                isActive(item.href) ? "page" : undefined
                            }
                        >
                            {item.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</nav>

<style>
    .nav {
        position: fixed;
        top: 0;
        z-index: 50;
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        width: 100%;
        border-bottom: var(--color-brand-primary) 1px solid;
        background-color: rgba(245, 245, 247, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: var(--shadow-image);
        align-self: center;
        height: 64px;
        box-sizing: border-box;
        flex-wrap: wrap;
    }

    .nav__inner {
        width: 100%;
        grid-column: 2 / span 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .nav-logo {
        left: 0%;
        right: 0.07%;
        top: 0%;
        bottom: 0.19%;
    }

    svg {
        fill: var(--color-text-primary);
    }

    .nav__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 28px;
        align-items: center;
    }

    .nav__link {
        text-decoration: none;
        color: var(--color-text-primary);
        font-size: 16px;
        line-height: 1;
        letter-spacing: 0.08em;
        padding: 8px 6px;
        border-radius: 4px;
        transition:
            background-color var(--transition-fast),
            color var(--transition-fast);
    }

    .nav__link:hover {
        background: rgba(17, 24, 39, 0.06);
    }

    .nav__link:focus-visible {
        outline: 3px solid rgba(72, 146, 190, 0.35);
        outline-offset: 4px;
    }

    .nav__link--active {
        text-decoration: underline;
        text-underline-offset: 10px;
        text-decoration-color: var(--color-brand-primary);
        text-decoration-thickness: 1px;
    }

    /* Hamburger button — hidden on desktop */
    .nav__toggle {
        display: none;
    }

    /* ===== MOBILE ===== */
    @media (max-width: 768px) {
        .nav {
            height: 64px;
            gap: 0;
        }

        .nav__list {
            transition: height 220ms ease;
        }

        /* Hamburger visible on mobile */
        .nav__toggle {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 5px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 6px 4px;
            margin-inline-start: auto;
        }

        .nav__toggle span {
            display: block;
            width: 22px;
            height: 2px;
            background: var(--color-text-dark);
            border-radius: 2px;
            transition:
                transform 220ms ease,
                opacity 220ms ease;
        }

        /* Animate to X when open */
        .nav__toggle[aria-expanded="true"] span:nth-child(1) {
            transform: translateY(7px) rotate(45deg);
        }
        .nav__toggle[aria-expanded="true"] span:nth-child(2) {
            opacity: 0;
        }
        .nav__toggle[aria-expanded="true"] span:nth-child(3) {
            transform: translateY(-7px) rotate(-45deg);
        }

        .nav__toggle[aria-expanded="true"] + .nav-menu {
            height: auto;
        }

        /* Nav list hidden by default, full-width row when open */
        .nav__list {
            display: none;
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
            width: 100%;
            height: 0;
            padding: 8px 0 4px;
            margin-top: 12px;
            border-top: 1px solid #e5e7eb;
            background-color: var(--color-surface-background);
            transition: height 350ms ease-in-out;
        }

        .nav__list.is-open {
            display: flex;
            flex-direction: column;
            position: absolute;
            top: 52px;
            left: 0;
            height: auto;
            overflow: hidden;
        }

        .nav__item {
            width: 100%;
        }

        .nav__link {
            display: block;
            width: 100%;
            padding: 13px 24px;
            border-bottom: 1px solid #f3f4f6;
            border-radius: 0;
            font-size: 15px;
        }

        .nav__link:hover {
            background: none;
            color: var(--color-brand-secondary);
        }
    }
</style>

<script>
    function initNav() {
        const toggle =
            document.querySelector<HTMLButtonElement>(".nav__toggle");
        const menu = document.querySelector<HTMLElement>("#nav-menu");
        if (!toggle || !menu) return;

        toggle.onclick = () => {
            const open = menu.classList.toggle("is-open");
            toggle.setAttribute("aria-expanded", String(open));
            toggle.setAttribute(
                "aria-label",
                open ? "Close navigation" : "Open navigation",
            );
        };

        // Close when a link is clicked
        menu.querySelectorAll(".nav__link").forEach((link) => {
            link.addEventListener("click", () => {
                menu.classList.remove("is-open");
                toggle.setAttribute("aria-expanded", "false");
                toggle.setAttribute("aria-label", "Open navigation");
            });
        });
    }

    document.addEventListener("astro:page-load", initNav);
</script>
