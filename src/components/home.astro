---
import { renderRichText } from "@storyblok/astro";
import { getStory, sbImage } from "../lib/storyblok";
import HeroCarousel from "./HeroCarousel.tsx";

const story = await getStory("home");
const content = story?.content;

const heroImages: string[] =
	content?.hero_images?.map((img: any) => sbImage(img.filename, 1600)).filter(Boolean) ??
	[content?.hero_image?.filename].filter(Boolean).map((url: string) => sbImage(url, 1600));

const taglineHtml: string = content?.tagline
	? (renderRichText(content.tagline) ?? "")
	: "";
const ctaLabel: string = content?.cta_label ?? "Portfolio";
---

<section class="hero__content">
	<HeroCarousel client:load images={heroImages} showDotNav={false} />
</section>

<div class="hero__tagline-row">
	{taglineHtml && <div class="hero__tagline" set:html={taglineHtml} />}
	<a href="/portfolio" class="btn-pill hero__cta-btn">{ctaLabel}</a>
</div>
<hr class="hero__keyline" />

<style>
	:global(:root) {
		color-scheme: light;
	}

	/* ===== HERO CONTENT ===== */
	.hero__content {
		position: relative;
		grid-column: 1 / -1;
		width: 100vw;
		height: 100vh;
		margin-top: -64px;
		margin-inline-start: calc(50% - 50vw);
	}

	/* ===== TAGLINE ROW ===== */
	.hero__tagline-row {
		grid-column: 4 / span 6;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 64px;
		padding-block: 64px;
	}

	.hero__tagline {
		margin: 0;
		font-size: var(--text-md);
		font-weight: 100;
		letter-spacing: 0.025em;
		color: var(--color-text-primary);
	}

	.hero__keyline {
		grid-column: 1 / -1;
		border: none;
		height: 1px;
		background-color: var(--color-brand-primary);
		margin: 0 0 16px;
	}

	.hero__tagline :global(p) {
		margin: 0;
	}

	/* ===== MOBILE ===== */
	@media (max-width: 768px) {
		.hero__content {
			height: 60vw;
			min-height: 280px;
			margin-top: 0;
		}

		.hero__cta-buttons {
			bottom: 16px;
			gap: 16px;
		}

		.hero__tagline-row {
			grid-column: 1 / -1;
			padding-inline: 24px;
		}

		.hero__cta-btn {
			font-size: 15px;
			padding: 12px 32px;
		}
	}
</style>
