---
import { getStory, sbImage } from "../lib/storyblok";
import { renderRichText } from "@storyblok/astro";

const story = await getStory("design-build");
const content = story?.content;
// Support both a root content type with direct fields and a body blocks array
const blok = content?.body?.[0] ?? content;

const bodyHtml: string = blok?.body
	? (renderRichText(blok.body) ?? "")
	: "";

const images: string[] = (blok?.images as { filename: string }[] | undefined)
	?.map((img) => sbImage(img.filename, 1200))
	.filter(Boolean) ?? [];
---

<hr class="keyline" />

<section class="design-build" id="design-build">
	<h2 class="design-build__heading">
		<span class="design-build__word">
			<span>D</span><span>E</span><span>S</span><span>I</span><span>G</span><span>N</span>
		</span>
		<hr class="design-build__hairline" />
		<span class="design-build__word">
			<span>B</span><span>U</span><span>I</span><span>L</span><span>D</span>
		</span>
	</h2>
	<div class="design-build__img-mobile">
		{images[0] && <img src={images[0]} alt="" />}
	</div>
	<div class="design-build__images">
		<div class="design-build__img-stack">
			<div class="design-build__img-slot design-build__img-slot--1">
				{images[0] && <img src={images[0]} alt="" />}
			</div>
			<div class="design-build__img-slot design-build__img-slot--2">
				{images[1] && <img src={images[1]} alt="" />}
			</div>
			<div class="design-build__img-slot design-build__img-slot--3">
				{images[2] && <img src={images[2]} alt="" />}
			</div>
		</div>
	</div>
	{bodyHtml
		? <div class="design-build__body" set:html={bodyHtml} />
		: <div class="design-build__body">
				<p>At Bicardo Builders, exceptional residential design and construction begin with a fully integrated Design-Build process.</p>
				<p>Design-Build is an ideal delivery method for a wide range of residential projects, from remodels and renovations to custom luxury homes. By bringing design, planning, budgeting, and construction together under one experienced team, we create a more efficient process built on clear communication, responsive decision-making, and greater cost control.</p>
				<p>The result is a streamlined experience that saves time, maximizes value, and delivers exceptional craftsmanship from concept to completion.</p>
				<p>If you are considering a residential construction project, we invite you to explore the benefits of our Design-Build services. We look forward to learning about your vision and helping bring it to life.</p>
			</div>
	}
</section>

<style>
	.keyline {
		grid-column: 1 / -1;
		border: none;
		height: 1px;
		background-color: var(--color-brand-primary);
		margin: 0 0 16px;
	}

	.design-build {
		--img-w: clamp(60px, calc(33.78vw - 222px), 240px);
		grid-column: 1 / -1;
		padding: 48px 0;
		display: grid;
		grid-template-columns: 5fr 48px 6fr;
		grid-template-rows: auto 1fr;
		grid-template-areas:
			"heading . images"
			"body    . images";
		align-items: start;
	}

	.design-build__heading {
		grid-area: heading;
		display: inline-flex;
		flex-direction: column;
		align-items: stretch;
		margin: 0;
	}

	.design-build__images {
		grid-area: images;
		display: flex;
		justify-content: flex-end;
		align-items: center;
		align-self: start;
		container-type: inline-size;
		position: sticky;
		top: calc(50vh - var(--img-w) * 0.858);
		margin-top: calc(50vh - var(--img-w) * 0.858 - 48px);
	}

	.design-build__body {
		grid-area: body;
		min-width: 500px;
		font-size: var(--text-md);
		font-weight: 100;
		line-height: 1.7;
		color: var(--color-text-primary);
		padding-top: 32px;

		p {
			margin-top: 0;
			margin-bottom: 1.25em;

			&:last-child {
				margin-bottom: 0;
			}
		}
	}

	.design-build__word {
		display: flex;
		justify-content: space-between;
		gap: 0.12em;
		font-size: var(--text-xl);
		font-weight: 300;
		font-family: var(--font-manrope);
		color: var(--color-brand-primary);
		text-transform: uppercase;
		letter-spacing: 0;
	}

	.design-build__hairline {
		border: none;
		height: 1px;
		background-color: var(--color-brand-primary);
		margin: 4px 0;
		align-self: stretch;
	}

	.design-build__img-mobile {
		display: none;
	}

	/* ===== IMAGE STACK ===== */
	.design-build__img-stack {
		--img-w: min(40.55cqi, 240px);
		--overlap: calc(var(--img-w) * 0.267);
		--step-x: calc(var(--img-w) - var(--overlap));
		--step-y: calc(var(--img-w) * 0.75 - var(--overlap));

		position: relative;
		width: calc(var(--img-w) + var(--step-x) * 2);
		height: calc(var(--img-w) * 0.75 + var(--step-y) * 2);
	}

	.design-build__img-slot {
		position: absolute;
		width: var(--img-w);
		aspect-ratio: 4 / 3;
		background: var(--color-surface-muted);
		box-shadow: var(--shadow-image);
		cursor: pointer;
		transition: transform 300ms ease;
		overflow: hidden;

		img {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	}

	.design-build__img-slot:hover {
		transform: scale(1.35);
		z-index: 10;
	}

	.design-build__img-slot--1 {
		bottom: 0;
		left: 0;
		z-index: 3;
		transform-origin: left bottom;
	}

	.design-build__img-slot--2 {
		bottom: var(--step-y);
		left: var(--step-x);
		z-index: 2;
		transform-origin: center center;
	}

	.design-build__img-slot--3 {
		bottom: calc(var(--step-y) * 2);
		left: calc(var(--step-x) * 2);
		z-index: 1;
		transform-origin: right top;
	}

	/* ===== VERTICAL STACK (container ≤ 400px) ===== */
	@container (max-width: 400px) {
		.design-build__img-stack {
			display: flex;
			flex-direction: column;
			width: 100%;
			height: auto;
			gap: 16px;
		}

		.design-build__img-slot {
			position: relative;
			width: 100%;
			height: auto;
			bottom: auto;
			left: auto;
			transform-origin: center center;

			img {
				position: relative;
				inset: auto;
				display: block;
			}
		}

		.design-build__img-slot:hover {
			transform: scale(1.05);
		}
	}

	/* Parallax: images column fills heading+body rows; JS drives the transform */
	@media (min-width: 769px) and (max-width: 1140px) {
		.design-build__images {
			position: relative;
			align-self: stretch;
			align-items: flex-start;
			margin-top: 0;
			top: auto;
			transform: none;
		}

		.design-build__img-stack {
			will-change: transform;
		}
	}

	/* ===== MOBILE ===== */
	@media (max-width: 768px) {
		.design-build {
			display: flex;
			flex-direction: column;
		}

		.design-build__heading {
			order: 1;
			width: calc(10 / 12 * 100%);
			margin-inline: auto;
		}

		.design-build__img-mobile {
			order: 2;
			display: block;
			position: relative;
			width: 100%;
			aspect-ratio: 4 / 3;
			background: var(--color-surface-muted);
			box-shadow: var(--shadow-image);
			margin-top: 24px;
			margin-bottom: 24px;
			overflow: hidden;

			img {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
		}

		.design-build__body {
			order: 3;
			width: calc(10 / 12 * 100%);
			margin-inline: auto;
		}

		.design-build__images {
			display: none;
		}
	}
</style>

<script>
	let _scrollHandler: (() => void) | null = null;
	let _resizeObs: ResizeObserver | null = null;
	let _loadHandler: (() => void) | null = null;

	document.addEventListener('astro:page-load', () => {
		if (_scrollHandler) window.removeEventListener('scroll', _scrollHandler);
		if (_loadHandler) window.removeEventListener('load', _loadHandler);
		if (_resizeObs) _resizeObs.disconnect();

		const section = document.getElementById('design-build');
		if (!section) return;

		const stack = section.querySelector<HTMLElement>('.design-build__img-stack');
		const imagesCol = section.querySelector<HTMLElement>('.design-build__images');
		const body = section.querySelector<HTMLElement>('.design-build__body');

		if (!stack || !imagesCol || !body) return;

		let maxTranslate = 0;
		let factor = 0.8;

		function measure() {
			stack!.style.transform = '';
			const sectionRect = section!.getBoundingClientRect();
			const stackRect = stack!.getBoundingClientRect();
			const bodyRect = body!.getBoundingClientRect();

			// Use positions relative to section top so stale page-height is never an issue
			const stackRelBottom = stackRect.bottom - sectionRect.top;
			const bodyRelBottom = bodyRect.bottom - sectionRect.top;
			const sectionH = sectionRect.height;

			maxTranslate = Math.max(0, bodyRelBottom - stackRelBottom);

			// Derive factor: images reach maxTranslate exactly when section exits viewport top
			factor = maxTranslate > 0 && sectionH > maxTranslate
				? 1 - maxTranslate / sectionH
				: 0.8;
		}

		_scrollHandler = () => {
			if (imagesCol!.offsetWidth > 400 || window.innerWidth <= 768) {
				stack!.style.transform = '';
				return;
			}
			// section.getBoundingClientRect().top is negative once section has scrolled past viewport top
			const elapsed = Math.max(0, -section!.getBoundingClientRect().top);
			const translateY = Math.min(elapsed * (1 - factor), maxTranslate);
			stack!.style.transform = `translateY(${translateY}px)`;
		};

		// Re-measure after all assets load in case images shifted the layout
		_loadHandler = () => { measure(); _scrollHandler?.(); };
		window.addEventListener('load', _loadHandler);

		_resizeObs = new ResizeObserver(() => { measure(); _scrollHandler?.(); });
		_resizeObs.observe(section);

		measure();
		window.addEventListener('scroll', _scrollHandler, { passive: true });
		_scrollHandler();
	});
</script>
